# Frontend build stage
FROM node:18-alpine AS frontend-builder
WORKDIR /frontend
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build

# Backend build stage  
FROM golang:1.22.5-alpine AS backend-builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -a -installsuffix cgo -o main .

# Production stage with PostgreSQL + Redis + App + Nginx
FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=Europe/Istanbul

RUN apt-get update && apt-get install -y \
    postgresql-14 \
    postgresql-client-14 \
    postgresql-contrib-14 \
    redis-server \
    nginx \
    supervisor \
    wget \
    ca-certificates \
    tzdata \
    dos2unix \
    && rm -rf /var/lib/apt/lists/*

# PostgreSQL: IPv4 ve IPv6 dahil HERKESE ŞİFRESİZ GİRİŞ
RUN echo "host all all 0.0.0.0/0 trust" > /etc/postgresql/14/main/pg_hba.conf && \
    echo "host all all ::/0 trust" >> /etc/postgresql/14/main/pg_hba.conf && \
    echo "listen_addresses='*'" >> /etc/postgresql/14/main/postgresql.conf

# Redis: Dışarıdan bağlan, arkaplana atma
RUN sed -i 's/^bind 127.0.0.1 ::1/bind 0.0.0.0/' /etc/redis/redis.conf && \
    sed -i 's/^protected-mode yes/protected-mode no/' /etc/redis/redis.conf && \
    sed -i 's/^daemonize yes/daemonize no/' /etc/redis/redis.conf

# Nginx
RUN rm -f /etc/nginx/sites-enabled/default

WORKDIR /app

COPY --from=backend-builder /app/main .
COPY --from=frontend-builder /frontend/dist /var/www/html
COPY config.yaml .
COPY database/init ./database/init

# Nginx config
RUN echo 'server { \
    listen 80; \
    server_name localhost; \
    root /var/www/html; \
    index index.html; \
    location / { try_files $uri $uri/ /index.html; } \
    location /api { \
        proxy_pass http://localhost:4040; \
        proxy_set_header Host $host; \
        proxy_set_header X-Real-IP $remote_addr; \
    } \
}' > /etc/nginx/sites-available/frontend

RUN ln -s /etc/nginx/sites-available/frontend /etc/nginx/sites-enabled/

# Supervisor
RUN mkdir -p /var/log/supervisor
COPY docker/supervisord.conf /etc/supervisor/conf.d/supervisord.conf

# Scripts
COPY docker/init-db.sh /app/init-db.sh
COPY docker/start-backend.sh /app/start-backend.sh
RUN dos2unix /app/init-db.sh && chmod +x /app/init-db.sh && \
    dos2unix /app/start-backend.sh && chmod +x /app/start-backend.sh

# Permissions
RUN mkdir -p /var/log/postgresql && \
    chown postgres:postgres /var/log/postgresql

EXPOSE 80 4040 5432 6379

HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://localhost:80 || exit 1

CMD ["/usr/bin/supervisord", "-c", "/etc/supervisor/conf.d/supervisord.conf"]